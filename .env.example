# ============================================================
# Student AI Hub — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# ============================================================

# --- Firebase ---
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# --- Google Gemini AI ---
VITE_GEMINI_API_KEY=AIzaSy...

# --- Judge0 (RapidAPI) ---
VITE_JUDGE0_API_KEY=your-rapidapi-key

# --- Job APIs ---
VITE_ADZUNA_APP_ID=your-app-id
VITE_ADZUNA_APP_KEY=your-app-key

# --- Stripe ---
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
VITE_STRIPE_PRO_MONTHLY_PRICE_ID=price_...
VITE_STRIPE_PRO_YEARLY_PRICE_ID=price_...
VITE_STRIPE_PREMIUM_MONTHLY_PRICE_ID=price_...
VITE_STRIPE_PREMIUM_YEARLY_PRICE_ID=price_...

# --- Upstash Redis ---
VITE_UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
VITE_UPSTASH_REDIS_REST_TOKEN=your-token

# --- Analytics ---
VITE_POSTHOG_KEY=phc_...
VITE_POSTHOG_HOST=https://app.posthog.com
VITE_GA4_MEASUREMENT_ID=G-...

# --- Error Monitoring ---
VITE_SENTRY_DSN=https://...@sentry.io/...
