# ====================================================
# STUDENT AI HUB - ENVIRONMENT CONFIGURATION BLUEPRINT
# ====================================================

# --- AI CORE CONFIGURATION ---
# Gemini AI SDK token. Custom keys are injected through AI Studio Secrets Panel.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# Platform host URL
APP_URL="http://localhost:3000"


# --- CLERK AUTHENTICATION CONFIGURATION ---
# Public publishable key for Frontend Clerk SPA components
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."

# Secret server key (Keep extremely secure - NEVER expose key to the client!)
CLERK_SECRET_KEY="sk_test_..."

# Clerk default routing config for customized Next 15 authentication screens
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# Secret SVIX signature verify key generated inside Clerk -> Webhooks panel
CLERK_WEBHOOK_SECRET="whsec_..."


# --- SUPABASE DATABASE CONFIGURATION ---
# Public Supabase database connection and routing endpoint
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"

# Public anon database role key (governed by Row Level Security)
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOi..."

# Private server admin role key (Bypasses RLS - keep extremely secure on server!)
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi...service-role-key"
