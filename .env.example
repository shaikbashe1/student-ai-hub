# ====================================================
# STUDENT AI HUB — ENVIRONMENT CONFIGURATION
# ====================================================
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file to Git.

# ── APP ──────────────────────────────────────────────
APP_URL="http://localhost:3000"

# ── AI CORE ──────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# ── SUPABASE (required for authentication) ────────────
# Get from: Supabase Dashboard → Settings → API
#
# ⚠️  IMPORTANT: In this Vite project, client-side env vars MUST be prefixed VITE_
#     (not NEXT_PUBLIC_). Server-side vars use no prefix.
#
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# Server-side only — Service Role key (bypasses RLS; keep VERY secure)
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...service_role..."

# ── FIREBASE FIRESTORE (existing backend) ─────────────
# Firebase config is loaded from firebase-applet-config.json
# No env vars needed for Firebase — config file is already set up.

# ── EMAIL (Resend) ────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY="re_..."

# ── STRIPE BILLING (optional for monetization) ───────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_PREMIUM_PRICE_ID="price_..."

# ── CODE EXECUTION (Judge0) ───────────────────────────
# Get from: https://rapidapi.com/judge0-official/api/judge0-ce
JUDGE0_API_KEY="your_rapidapi_key"
JUDGE0_HOST="judge0-ce.p.rapidapi.com"
