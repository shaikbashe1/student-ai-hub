rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────────────────────────────────────
    // Helper Functions
    // ──────────────────────────────────────────────────────────────────────────

    // Get the caller's profile from Firestore (server-SDK bypasses these rules)
    function getProfile(uid) {
      return get(/databases/$(database)/documents/profiles/$(uid)).data;
    }

    // Is the request authenticated?
    function isAuthenticated() {
      return request.auth != null;
    }

    // Is the request from a verified admin?
    function isAdmin() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/profiles/$(request.auth.uid))
        && getProfile(request.auth.uid).role == 'admin';
    }

    // Is the caller the owner of this document?
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // ──────────────────────────────────────────────────────────────────────────
    // Profiles — each user can only read/write their own profile
    // ──────────────────────────────────────────────────────────────────────────
    match /profiles/{userId} {
      // Read own profile OR admin reads any profile
      allow read: if isOwner(userId) || isAdmin();

      // Create own profile on first login (server-side does this, but allow
      // client fallback if needed)
      allow create: if isOwner(userId)
        && request.resource.data.keys().hasAll(['id','name','email','role','daily_prompt_count'])
        && request.resource.data.role == 'student';     // new profiles are always students

      // Update only own profile; cannot self-promote to admin
      allow update: if isOwner(userId)
        && request.resource.data.role == resource.data.role  // role immutable client-side
        && request.resource.data.email == resource.data.email; // email immutable client-side

      // Only admins can delete profiles
      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────────────────
    // Saved Items — private per user
    // ──────────────────────────────────────────────────────────────────────────
    match /saved_items/{itemId} {
      allow read:   if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.user_id == request.auth.uid
        && request.resource.data.keys().hasAll(['user_id','item_type','item_id','created_at']);
      allow delete: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow update: if false; // Bookmarks are create/delete only
    }

    // ──────────────────────────────────────────────────────────────────────────
    // AI Chat Sessions — private per user
    // ──────────────────────────────────────────────────────────────────────────
    match /chat_sessions/{sessionId} {
      allow read, write: if isAuthenticated()
        && (resource == null || resource.data.user_id == request.auth.uid)
        && (request.resource == null || request.resource.data.user_id == request.auth.uid);

      match /messages/{messageId} {
        allow read, write: if isAuthenticated()
          && get(/databases/$(database)/documents/chat_sessions/$(sessionId)).data.user_id == request.auth.uid;
      }
    }

    // ──────────────────────────────────────────────────────────────────────────
    // AI Tools — public read, admin write
    // ──────────────────────────────────────────────────────────────────────────
    match /ai_tools/{toolId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────────────────
    // Internships — public read, admin write
    // ──────────────────────────────────────────────────────────────────────────
    match /internships/{internshipId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────────────────
    // Hackathons — public read, admin write
    // ──────────────────────────────────────────────────────────────────────────
    match /hackathons/{hackathonId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────────────────
    // Blog Posts — published posts are public, admin manages all
    // ──────────────────────────────────────────────────────────────────────────
    match /blog_posts/{postId} {
      allow read: if resource.data.is_published == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────────────────
    // Newsletter Subscribers — write-only for new subscriptions
    // ──────────────────────────────────────────────────────────────────────────
    match /newsletter_subscribers/{subId} {
      allow create: if request.resource.data.keys().hasAll(['email','created_at'])
        && request.resource.data.email is string;
      allow read, update, delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────────────────
    // Analytics Events — write-only for authenticated users, admin reads
    // ──────────────────────────────────────────────────────────────────────────
    match /analytics_events/{eventId} {
      allow create: if isAuthenticated();
      allow read:   if isAdmin();
      allow update, delete: if false;
    }

    // ──────────────────────────────────────────────────────────────────────────
    // Deny all other paths by default
    // ──────────────────────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
