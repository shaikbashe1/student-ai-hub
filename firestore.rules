rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return isAuth() && request.auth.uid == uid; }
    function getRole() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role; }
    function hasRole(role) { return isAuth() && getRole() == role; }
    function isAdmin() { return hasRole('admin'); }
    function isMentor() { return hasRole('mentor') || isAdmin(); }
    function isRecruiter() { return hasRole('recruiter') || isAdmin(); }

    // Users collection
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) && request.resource.data.role == 'student';
      allow update: if isOwner(uid) && (
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['role', 'plan', 'daily_ai_limit'])
      ) || isAdmin();
      allow delete: if isAdmin();
    }

    // AI Conversations
    match /ai_conversations/{convId} {
      allow read, write: if isAuth() && resource.data.user_id == request.auth.uid;
      allow create: if isAuth() && request.resource.data.user_id == request.auth.uid;
      match /messages/{msgId} {
        allow read, write: if isAuth();
      }
    }

    // Resume analyses — user-scoped
    match /resume_analyses/{docId} {
      allow read, write: if isAuth() && (
        resource == null || resource.data.user_id == request.auth.uid
      );
    }

    // Learning roadmaps — user-scoped
    match /learning_roadmaps/{docId} {
      allow read, write: if isAuth() && (
        resource == null || resource.data.user_id == request.auth.uid
      );
    }

    // Study plans — user-scoped
    match /study_plans/{docId} {
      allow read, write: if isAuth() && (
        resource == null || resource.data.user_id == request.auth.uid
      );
    }

    // Code submissions — user-scoped
    match /code_submissions/{docId} {
      allow read, write: if isAuth() && (
        resource == null || resource.data.user_id == request.auth.uid
      );
    }

    // Blog posts — public read if published, mentor/admin write
    match /blog_posts/{postId} {
      allow read: if resource.data.status == 'published' || isMentor();
      allow create, update: if isMentor();
      allow delete: if isAdmin();
    }

    // Internships — public read, recruiter/admin write
    match /internships/{itemId} {
      allow read: if true;
      allow create, update: if isRecruiter();
      allow delete: if isAdmin();
    }

    // Hackathons — public read, admin write
    match /hackathons/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Coding challenges — public read, admin write
    match /coding_challenges/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Subscriptions — user read, no direct write (webhook only)
    match /subscriptions/{subId} {
      allow read: if isAuth() && resource.data.user_id == request.auth.uid;
      allow write: if false;
    }

    // Achievements — user read, function write only
    match /achievements/{docId} {
      allow read: if isAuth() && resource.data.user_id == request.auth.uid;
      allow write: if false;
    }

    // Audit logs — write-only for auth users, admin read
    match /audit_logs/{logId} {
      allow create: if isAuth();
      allow read: if isAdmin();
      allow update, delete: if false;
    }
  }
}
